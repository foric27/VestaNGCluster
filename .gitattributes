# Line endings: use system default (autocrlf=true on Windows)
* text=auto

# Force LF for these files (important for cross-platform)
*.kt text eol=lf
*.java text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.bat text eol=crlf
