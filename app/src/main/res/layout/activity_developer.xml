<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_content_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/backButton"
                    style="@style/Widget.Foric27Cluster.Button.Dismiss"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/developer_back" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/developer_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/developer_title_size"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/versionInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/screen_body_size" />

            <TextView
                android:id="@+id/developerHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/developer_autosave_hint"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/screen_body_size" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/screen_section_spacing"
                android:background="@drawable/bg_metric_card"
                android:orientation="vertical"
                android:padding="@dimen/screen_card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/developer_update_channel_title"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/screen_caption_size" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/developer_update_channel_hint"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/screen_body_size" />

                <RadioGroup
                    android:id="@+id/updateChannelRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/updateChannelRollingRadio"
                        style="@style/Widget.Foric27Cluster.Radio.Mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/app_update_channel_rolling"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/updateChannelStableRadio"
                        style="@style/Widget.Foric27Cluster.Radio.Mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/app_update_channel_stable"
                        android:textColor="@color/text_primary" />
                </RadioGroup>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/settingsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/screen_section_spacing"
                android:orientation="vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/resetAllBtn"
                style="@style/Widget.Foric27Cluster.Button.Dismiss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/screen_section_spacing"
                android:text="@string/developer_reset_all" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/exportLogcatBtn"
                style="@style/Widget.Foric27Cluster.Button.Dismiss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:text="@string/developer_export_logcat" />

            <TextView
                android:id="@+id/developerStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingBottom="20dp"
                android:text="@string/developer_hint"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/screen_body_size" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
