<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_content_padding">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/screen_title_size"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/noticePanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/screen_section_spacing"
                android:background="@drawable/bg_warning_panel"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="@dimen/screen_card_padding"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/noticeTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/inline_notice_title_warning"
                        android:textColor="@color/warning"
                        android:textSize="@dimen/screen_body_size"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/noticeDismissBtn"
                        style="@style/Widget.Foric27Cluster.Button.Dismiss"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/inline_notice_dismiss" />
                </LinearLayout>

                <TextView
                    android:id="@+id/noticeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/screen_notice_spacing"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/screen_body_size" />
            </LinearLayout>

            <TextView
                android:id="@+id/statusHeadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/screen_block_spacing"
                android:text="@string/status_recovering_headline"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/screen_headline_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusSubline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/status_recovering_subline"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/screen_subline_size" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/screen_block_spacing"
                android:background="@drawable/bg_metric_card"
                android:orientation="vertical"
                android:padding="@dimen/screen_card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/stream_mode_title"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/screen_caption_size" />

                <RadioGroup
                    android:id="@+id/modeRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/modeNavRadio"
                        style="@style/Widget.Foric27Cluster.Radio.Mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_mode_navigation"
                        android:drawablePadding="12dp"
                        android:text="@string/stream_mode_nav"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/modeMedRadio"
                        style="@style/Widget.Foric27Cluster.Radio.Mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_mode_media"
                        android:drawablePadding="12dp"
                        android:text="@string/stream_mode_med"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/modeAbsRadio"
                        style="@style/Widget.Foric27Cluster.Radio.Mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_mode_trip"
                        android:drawablePadding="12dp"
                        android:text="@string/stream_mode_abs"
                        android:textColor="@color/text_primary" />
                </RadioGroup>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/restartStreamBtn"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/screen_section_spacing"
                android:text="@string/main_restart_stream_button" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/screen_section_spacing"
                android:background="@drawable/bg_metric_card"
                android:orientation="vertical"
                android:padding="@dimen/screen_card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ftp_title"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/screen_caption_size" />

                <TextView
                    android:id="@+id/ftpStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/screen_body_size" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/screen_footer_spacing"
                android:layout_marginBottom="8dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/versionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/screen_footer_text_size" />

                <TextView
                    android:id="@+id/developerTelegramText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="@string/developer_telegram"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/screen_link_text_size" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
