<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/stream_placeholder_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="380dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_media_cover_art"
            android:contentDescription="@string/stream_placeholder_title"
            android:padding="16dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_dialog_map"
            app:tint="@color/oem_cluster_subtitle" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/stream_placeholder_source"
                android:textColor="@color/oem_cluster_subtitle"
                android:textSize="12sp"
                tools:text="Навигация" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/stream_placeholder_title"
                android:textColor="@color/oem_cluster_title"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Кластерный вывод недоступен" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/stream_placeholder_subtitle"
                android:textColor="@color/oem_cluster_subtitle"
                android:textSize="12sp"
                tools:text="Ожидаю запуск навигации" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
